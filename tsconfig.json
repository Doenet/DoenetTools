// This is the root tsconfig file that references all packages. It does not contain any compiler options itself, but it allows us to build all packages at once using `tsc -b`.
{
  "files": [],
  "references": [
    { "path": "packages/shared" },
    { "path": "apps/web" },
    { "path": "apps/app/tsconfig.build.json" },
    { "path": "apps/api/tsconfig.build.json" }
  ]
}
