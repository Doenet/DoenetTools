{
  "name": "@doenet-tools/tests-cypress",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Cypress end-to-end tests for DoenetTools",
  "scripts": {
    "lint": "eslint --fix",
    "lint:check": "eslint",
    "test": "cypress open",
    "test:all": "cypress run -b 'chrome' --config video=false --headless",
    "test:group1": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@group1',grepFilterSpecs=true,grepOmitFiltered=true",
    "test:group2": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@group2',grepFilterSpecs=true,grepOmitFiltered=true",
    "test:group3": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@group3',grepFilterSpecs=true,grepOmitFiltered=true",
    "test:group4": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='-@group1+-@group2+-@group3+-@brittle1+-@brittle2+-@brittle3',grepFilterSpecs=true,grepOmitFiltered=true",
    "test:skip-brittle": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='-@brittle1+-@brittle2+-@brittle3',grepFilterSpecs=true,grepOmitFiltered=true",
    "test:brittle1": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@brittle1',grepFilterSpecs=true,grepOmitFiltered=true",
    "test:brittle2": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@brittle2',grepFilterSpecs=true,grepOmitFiltered=true",
    "test:brittle3": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@brittle3',grepFilterSpecs=true,grepOmitFiltered=true",
    "test:parallel": "cypress-parallel -s test:all -t 4 -d e2e -n ../../node_modules/cypress-multi-reporters"
  },
  "dependencies": {
    "@cypress/grep": "^6.0.0",
    "@doenet-tools/shared": "^1.0.0",
    "@types/luxon": "^3.7.1",
    "cssesc": "^3.0.0",
    "cypress-file-upload": "^5.0.8",
    "cypress-iframe": "^1.0.1",
    "cypress-plugin-tab": "^1.0.5",
    "cypress-wait-until": "^3.0.2",
    "wick-a11y": "^2.5.0"
  },
  "devDependencies": {
    "@types/cssesc": "^3.0.2"
  }
}
