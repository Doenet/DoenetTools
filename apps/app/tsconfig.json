{
  "extends": "../../configs/typescript/tsconfig.react.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "outDir": "dist",
    "tsBuildInfoFile": "../../.tsbuildinfo/apps/app.tsbuildinfo",
    "types": ["vite/client", "cypress", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "cypress/**/*.ts",
    "cypress/**/*.tsx",
    "cypress.config.ts"
  ],
  "references": [
    {
      "path": "../../packages/shared"
    }
  ]
}
