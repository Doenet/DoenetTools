{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "../../.tsbuildinfo/apps/app.build.tsbuildinfo",
    "types": ["vite/client", "node"]
  },
  "references": [
    {
      "path": "../../packages/shared"
    }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.cy.ts",
    "src/**/*.cy.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
