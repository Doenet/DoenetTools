PROJECT=doenet
FARGATE_CLUSTER=dev3
AWS_REGION=us-east-2
TEMPLATE_BUCKET=doenet-cf-dev
SSO_ACCOUNT_NAME=CSE-doenet-dev
SAM_CONFIG_ENV=dev

declare -g -A STACKS
STACKS['dev3-doenet-networking']='networking'
STACKS['dev3-doenet-repositories']='repositories'
STACKS['dev3-doenet-common']='service-common'
STACKS['dev3-doenet-mysql']='service'
STACKS['dev3-doenet']='service'
STACKS['dev3-doenet-frontend']='s3-hosted-stackset'
STACKS['dev3-discourse-forums']='discourse-forums-ec2'


declare -g -a STACK_ORDER
STACK_ORDER=(
  dev3-doenet-networking
  dev3-doenet-repositories
  dev3-doenet-common
  dev3-doenet-mysql
  dev3-doenet
  dev3-doenet-frontend
)

declare -g -a SAM_STACKS
SAM_STACKS=(
)

declare -g -A DOCKER_IMAGES
